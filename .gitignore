# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (often handled by go.mod now, but good practice to list if using vendor/)
vendor/

# Go workspace file
go.work
go.work.sum

# Environment file
.env

# Editor/IDE specific files
.idea/
